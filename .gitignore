.claude/settings.local.json
.claudeignore
*.env
.env
*.log
/tmp/
.DS_Store
.~lock.*
.venv/
__pycache__/
node_modules/

# Session state (cookies, tokens)
**/state/facebook_session.json
**/state/instagram_session.json
**/state/telegram_config.json
social-automation/.claude/state/

# Content drafts and site assets (local only). Two entries: the directory
# itself (when it lived at repo root) and, now that the real data moved to
# persona/brands/dogfoodandfun/, the backward-compat symlink left in its
# place for the 19 native launchd jobs that still hardcode this path --
# gitignore's trailing-slash form only matches directories, not symlinks.
dogfoodandfun/
dogfoodandfun
/tools/
post_instructions.md
CLAUDE.md

# Generated runtime files
social-automation/data/site_content_cache.json
social-automation/logs/
social-automation/backups/
social-automation/config.json

# Recipe-publisher runtime + local artifacts
social-automation/recipe-publisher/state/
social-automation/recipe-publisher/seeds/
social-automation/recipe-publisher/_audit/
social-automation/recipe-publisher/pytest-cache-files-*/

# Generated media (Reel pipeline: slides, music beds, narration, composed mp4s)
*.mp4
*.mp3
*.aiff
*.wav

# Campaign work-directories (per-campaign scratch space — keep local)
campaigns/
# …but the campaigns library module is source code, not scratch
!social-automation/lib/campaigns/
!social-automation/lib/campaigns/**
# …same for the tests covering it
!social-automation/tests/lib/campaigns/
!social-automation/tests/lib/campaigns/**
# …but never the bytecode caches the `**` un-ignore re-included
social-automation/lib/campaigns/**/__pycache__/
*.pyc

# AI agent scratch + session state (keep local, never commit)
$CLAUDE_SCRATCHPAD_DIR/
**/$CLAUDE_SCRATCHPAD_DIR/
.claude/state/
**/.claude/state/

# Test artifacts
.coverage
.coverage.*
htmlcov/
coverage.xml

# Stray AI-generated images at repo root
Gemini_Generated_Image_*.png
Gemini_Generated_Image_*.jpg
Gemini_Generated_Image_*.jpeg

# Throwaway dedup probes (leading underscore = scratch)
social-automation/scripts/_dedup_*

# Recipe-seed ideator (local-only iteration; weekly recipe-ideator cron
# invokes `python -m ideator` from this directory)
social-automation/recipe-publisher/ideator/
social-automation/recipe-publisher/seeds/seeds.json

# orchestrator per-turn telemetry (file tracked dir, ignore the churning state files)
.claude/state/delegation_violations.json
.claude/state/turn_durations.json
.claude/state/turn_start_timestamp.txt
.claude/state/last_turn_duration.txt
