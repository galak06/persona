{
  "_comment": "Persona — Brand Social Automation Config. Copy to config.json and fill in your values.",
  "_version": "1.0",

  "site": {
    "name": "Your Brand Name",
    "url": "https://yourbrand.com",
    "rss_feed": "https://yourbrand.com/feed/",
    "sitemap": "https://yourbrand.com/sitemap.xml",
    "brand_persona": "Your Persona Name",
    "mascot_name": "Your Mascot",
    "niche": "describe your niche (e.g. dog food reviews, GPS trackers, running with dogs)",
    "target_audience": "describe your target audience (e.g. dog owners in USA/Canada)"
  },

  "social_channels": {
    "facebook": {
      "enabled": true,
      "page_url": "https://www.facebook.com/yourpage",
      "page_name": "Your Page Name",
      "tracker_file": "data/trackers/groups_tracker.json",
      "tracker_sheet": "Groups Database"
    },
    "instagram": {
      "enabled": true,
      "profile_url": "https://www.instagram.com/yourhandle",
      "ig_username": "yourhandle",
      "hashtags_file": "data/config/instagram_accounts.csv"
    },
    "twitter": {
      "enabled": false,
      "profile_url": "",
      "note": "Set enabled: true and add profile_url to activate"
    },
    "tiktok": {
      "enabled": false,
      "profile_url": "",
      "note": "Set enabled: true and add profile_url to activate"
    }
  },

  "rate_limits": {
    "facebook": {
      "comments_per_day": 5,
      "group_visits_per_day": 6,
      "min_delay_between_comments_sec": 30,
      "max_delay_between_comments_sec": 120,
      "min_delay_between_group_visits_sec": 45,
      "max_delay_between_group_visits_sec": 180,
      "group_visit_schedule_hours": [9, 11, 14, 16, 18, 20]
    },
    "instagram": {
      "likes_per_day": 8,
      "comments_per_day": 2,
      "min_delay_between_likes_sec": 10,
      "max_delay_between_likes_sec": 45,
      "min_delay_between_comments_sec": 120,
      "max_delay_between_comments_sec": 180,
      "hashtag_rotation": {
        "monday_thursday": ["#yourniche1", "#yourniche2"],
        "tuesday_friday": ["#yourniche3", "#yourniche4"],
        "wednesday_saturday": ["#yourniche5", "#yourniche6"],
        "sunday": "best_of_week_queue",
        "always_scan": ["#yourniche7", "#yourniche8"]
      }
    }
  },

  "content_analysis": {
    "relevance_threshold": 0.70,
    "approval_threshold": 0.80,
    "site_cache_ttl_hours": 12,
    "site_cache_max_posts": 50,
    "site_crawl_depth": 2,
    "keywords": {
      "primary": ["keyword1", "keyword2", "keyword3"],
      "secondary": ["keyword4", "keyword5", "keyword6"],
      "brands_reviewed": ["brand1", "brand2", "brand3"]
    },
    "scoring_weights": {
      "primary_match": 0.40,
      "secondary_match": 0.30,
      "question_format": 0.20,
      "reviewed_brand_mention": 0.20,
      "comment_count_5_to_50": 0.10,
      "post_under_24h": 0.10,
      "comment_count_over_100": -0.30,
      "competitor_account": -0.50
    }
  },

  "approval_gates": {
    "first_post_to_new_group": true,
    "comment_contains_url": true,
    "all_instagram_comments": true,
    "borderline_relevance_score": true,
    "borderline_score_range_lo": 0.70,
    "borderline_score_range_hi": 0.80
  },

  "deduplication": {
    "ttl_days": 60,
    "cache_file": ".claude/state/dedup_cache.json"
  },

  "file_paths": {
    "state_dir": ".claude/state",
    "skills_dir": ".claude/skills",
    "logs_dir": "logs",
    "data_dir": "data",
    "lib_dir": "lib",
    "post_templates": "data/config/post_templates.json",
    "brand_voice_guide": "data/config/brand_voice_guide.md",
    "instagram_hashtags": "data/config/instagram_accounts.csv",
    "site_content_cache": "data/cache/site_content_cache.json",
    "comment_queue": ".claude/state/comment_queue.json",
    "dedup_cache": ".claude/state/dedup_cache.json",
    "rate_limit_tracker": ".claude/state/rate_limit_tracker.json",
    "last_run": ".claude/state/last_run.json",
    "engagement_log": "logs/engagement_log.jsonl",
    "error_log": "logs/errors.log",
    "audit_trail": "logs/audit_trail.json"
  },

  "voice_validation": {
    "blocked_medical_terms": [
      "clinical", "clinically proven", "studies show",
      "research indicates", "scientifically", "diagnosis", "symptoms",
      "treatment", "prescribe"
    ],
    "blocked_salesy_phrases": [
      "check out our", "visit our site", "click here", "buy now",
      "our product", "shop now", "affiliate", "promo code"
    ],
    "blocked_generic_openers": [
      "great post!", "love this!", "awesome!", "nice post", "amazing!"
    ],
    "min_comment_length": 40,
    "max_comment_length": 500,
    "must_end_with_question": true
  }
}
