# Persona — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Brand ─────────────────────────────────────────────────────────────────────
# Slug used as Redis key prefix. Should match your brand folder name.
PERSONA_BRAND=mybrand

# Path to the brand directory on the HOST. Used by docker-compose.worker.yml
# (mounted into the worker container as /brand — one worker per brand) and by
# host-run scripts (login scripts, CLI tools). The shared stack's `api`
# service instead mounts the whole brands/ root read-write; PERSONA_BRAND
# above selects which brand subfolder it resolves at runtime.
# Use an absolute path or a path relative to docker-compose.yml.
BRAND_DIR=./brands/mybrand

# ── WordPress ─────────────────────────────────────────────────────────────────
WP_URL=https://yourbrand.com
WP_USER=your_wp_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx   # generated in WP → Users → Application Passwords

# ── Facebook ──────────────────────────────────────────────────────────────────
FB_PAGE_ID=123456789012345
FB_PAGE_TOKEN=EAAxxxxxxxxxxxxxxx   # Page access token (long-lived)
FB_APP_ID=000000000000000          # From developers.facebook.com → Your App
FB_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Instagram ─────────────────────────────────────────────────────────────────
IG_ACCOUNT_ID=17841400000000000    # Instagram Business Account ID

# ── Pexels ────────────────────────────────────────────────────────────────────
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Local Postgres (brands, fb_groups, engagements, worker_runs, schedule_tasks) ──
# Used by lib/db.py. Matches the `postgres` service in docker-compose.yml —
# for the containerized api/worker this resolves via the `postgres` hostname;
# for host-run scripts, use `localhost:5432` (also matches DEFAULT_DSN in
# lib/db_pool.py if unset).
DATABASE_URL=postgresql://persona:persona@localhost:5432/persona

# Credentials the `postgres` container itself is created with (docker-compose.yml).
# Must stay in sync with the user:pass@.../dbname parts of DATABASE_URL above.
POSTGRES_USER=persona
POSTGRES_PASSWORD=persona
POSTGRES_DB=persona

# ── Supabase (still used by recipes_db / content_ideas / oauth_tokens — NOT
# migrated to local Postgres this stage; optional otherwise) ──────────────────
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Telegram (approval bot) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=0000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100000000000   # Your chat or group ID

# ── AI / LLM ──────────────────────────────────────────────────────────────────
VOICE_PROVIDER=anthropic          # anthropic | gemini | openai | ollama
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Reel pipeline ─────────────────────────────────────────────────────────────
JAMENDO_CLIENT_ID=xxxxxxxx        # https://developer.jamendo.com

# ── Affiliate ─────────────────────────────────────────────────────────────────
AMAZON_ASSOCIATES_TAG=yourtag-20  # From Amazon Associates dashboard

# ── OAuth callback base URL ───────────────────────────────────────────────────
# Set to your public domain when deploying; localhost works for local dev.
OAUTH_REDIRECT_BASE_URL=http://localhost:5001

# ── Redis ─────────────────────────────────────────────────────────────────────
# Set only if using an external Redis (default: the redis service in docker-compose)
# REDIS_URL=redis://localhost:6379/0
