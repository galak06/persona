    {
      "id": "site-analyzer",
      "skill": "site-analyzer",
      "script": null,
      "description": "Crawl dogfoodandfun.com RSS + sitemap, cache recent posts for comment context",
      "schedule": {
        "cron": "0 15 * * *",
        "cadence": "daily"
      },
      "output_file": "data/site_content_cache.json",
      "re_run_guard": true,
      "requires_browser": false,
      "requires_approval": false,
      "telegram_notify": true,
      "order": 10,
      "depends_on": [],
      "inputs": []
    },
    {
      "id": "comment-composer",
      "skill": "comment-composer",
      "script": null,
      "description": "Draft, validate, and post queued comments. Sends approvals via Telegram bot",
      "schedule": {
        "cron": "0 22 * * *",
        "cadence": "daily"
      },
      "output_file": "logs/engagement_log.jsonl",
      "re_run_guard": true,
      "requires_browser": true,
      "requires_approval": true,
      "approval_channel": "telegram",
      "approval_timeout_hours": 12,
