/v1/flows/guide":{"get":{"summary":"Get Flows Guide","description":"Static flow descriptions merged with live last-run state.","operationId":"get_flows_guide_api_v1_flows_guide_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/FlowGuideResponse"}}}}}}},"/api/v1/schedule/{label}/trigger":{"post":{"summary":"Trigger Schedule","description":"Fire a launchd job on demand via ``launchctl start <label>``.\n\nLabel is whitelisted against the ``com.dogfoodandfun.*`` namespace\nto keep this from being abused as a generic launchctl runner. All\nsubprocess args are list-form; no shell. Unless ``force=true`` is\npassed, the task's declared inputs in ``schedule.json`` must be\nfresh -- failing a precondition short-circuits with a 200 body\ncarrying ``ok=False`` and the human-readable reason.","operationId":"trigger_schedule_api_v1_schedule__label__trigger_post","parameters":[{"name":"label","in":"path","required":true,"schema":{"type":"string","title":"Label"}},{"name":"force","in":"query","required":false,"schema":{"type":"boolean","default":false,"title":"Force"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/TriggerResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/schedule/missing":{"get":{"summary":"List Missing Flows","description":"Return scheduled flows defined in schedule.json that aren't loaded in launchctl.","operationId":"list_missing_flows_api_v1_schedule_missing_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MissingFlowsResponse"}}}}}}},"/api/v1/schedule/{label}/log":{"get":{"summary":"Get Schedule Log","description":"Return the last N lines of the log file for a scheduled job.\n\nLabel is whitelisted against the ``com.dogfoodandfun.*`` namespace.\nLog path is read from the matching plist's ``StandardOutPath`` —\nnever user-supplied — so we cannot be coerced into reading arbitrary\nfiles via path traversal.","operationId":"get_schedule_log_api_v1_schedule__label__log_get","parameters":[{"name":"label","in":"path","required":true,"schema":{"type":"string","title":"Label"}},{"name":"lines","in":"query","required":false,"schema":{"type":"integer","maximum":1000,"minimum":1,"default":200,"title":"Lines"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/LogTailResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/schedule/{label}/artifact":{"get":{"summary":"Get Schedule Artifact","description":"Return the JSON content of the output_file for a scheduled job.\n\nSecurely reads only files declared in schedule.json as output_file.","operationId":"get_schedule_artifact_api_v1_schedule__label__artifact_get","parameters":[{"name":"label","in":"path","required":true,"schema":{"type":"string","title":"Label"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","additionalProperties":true,"title":"Response Get Schedule Artifact Api V1 Schedule  Label  Artifact Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"ActivityEntry":{"properties":{"date":{"type":"string","title":"Date"},"timestamp":{"type":"string","title":"Timestamp"},"action":{"type":"string","enum":["comment","like","group_post","reply","own_reply","page_post","feed_post","group_join","trace"],"title":"Action"},"platform":{"type":"string","enum":["facebook","instagram","wordpress","system"],"title":"Platform"},"target_name":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Target Name"},"target_url":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Target Url"},"content":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Content"},"reply_url":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Reply Url"}},"additionalProperties":true,"type":"object","required":["date","timestamp","action","platform"],"title":"ActivityEntry","description":"One row in ``logs/engagement_log.jsonl`` as exposed by ``/activity``.\n\nSome legacy rows in the JSONL file use ``action=\"group_join_request\"``;\nthe API layer normalises those to ``\"group_join\"`` before constructing\nthis model so the frontend only ever sees the canonical value. Older\nrows may also lack the ``date`` field — ``lib.activity_log`` derives\nit from ``timestamp`` so the UI can rely on both being present."},"ActivityResponse":{"properties":{"entries":{"items":{"$ref":"#/components/schemas/ActivityEntry"},"type":"array","title":"Entries"},"total":{"type":"integer","title":"Total"},"as_of":{"type":"string","title":"As Of"}},"type":"object","required":["entries","total","as_of"],"title":"ActivityResponse","description":"Envelope for ``GET /api/v1/activity``."},"ApproveBody":{"properties":{"text":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Text"},"fb_caption":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Fb Caption"},"ig_caption":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Ig Caption"}},"type":"object","title":"ApproveBody","description":"Body for ``POST /items/{id}/approve``.\n\nAll fields optional: a bare approve just commits the existing draft.\nPass ``text`` to override a comment, or ``fb_caption``/``ig_caption``\nto override a blog post pair before approval."},"BlogPostItem":{"properties":{"id":{"type":"string","title":"Id"},"status":{"type":"string","title":"Status","default":"pending"},"decided_by":{"anyOf":[{"type":"string","enum":["telegram","web_ui","auto"]},{"type":"null"}],"title":"Decided By"},"decided_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Decided At"},"created_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Created At"},"type":{"type":"string","const":"blog_post","title":"Type","default":"blog_post"},"post_title":{"type":"string","title":"Post Title","default":""},"post_url":{"type":"string","title":"Post Url","default":""},"post_id":{"type":"integer","title":"Post Id","default":0},"fb_caption":{"type":"string","title":"Fb Caption","default":""},"ig_caption":{"type":"string","title":"Ig Caption","default":""},"image_url":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Image Url"},"channel":{"anyOf":[{"type":"string","enum":["both","fb_only","ig_only"]},{"type":"null"}],"title":"Channel"}},"additionalProperties":true,"type":"object","required":["id"],"title":"BlogPostItem","description":"A WordPress post awaiting FB + IG caption sign-off.\n\n``channel`` is the per-platform fan-out decision set by the approver:\n\n- Web UI: ``POST /items/{id}/approve?channel=fb_only`` stamps this field\n  before flipping ``status`` to ``approved``.\n- Telegram: the reply parser in ``lib/notifier.py`` maps text replies\n  (``approve``/``fb``/``ig``) onto ``\"both\"``/``\"fb_only\"``/``\"ig_only\"``.\n\nThe publisher (``scripts/content_pipeline.py::stage_publish``) reads\n``channel`` after ``send_and_wait`` returns to decide which platforms to\nactually post to. ``None`` is valid only while the item is still pending\nor was skipped."},"CampaignDetail":{"properties":{"name":{"type":"string","title":"Name"},"last_run":{"anyOf":[{"type":"string","format":"date-time"},{"type":"null"}],"title":"Last Run"},"current_task_index":{"type":"integer","title":"Current Task Index","default":0},"last_status":{"type":"string","enum":["success","error","never"],"title":"Last Status","default":"never"},"ready_count":{"type":"integer","title":"Ready Count","default":0},"published_count":{"type":"integer","title":"Published Count","default":0},"has_prepare_tasks":{"type":"boolean","title":