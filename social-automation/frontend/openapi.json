{"openapi": "3.1.0", "info": {"title": "DogFoodAndFun Approval API", "description": "Localhost-only sidecar for parallel web/Telegram approvals.", "version": "0.2.0"}, "paths": {"/api/v1/pending": {"get": {"summary": "List Pending", "description": "All blog-post pairs + group-join candidates awaiting a decision.", "operationId": "list_pending_api_v1_pending_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PendingResponse"}}}}}}}, "/api/v1/activity": {"get": {"summary": "List Activity", "description": "Tail of ``logs/engagement_log.jsonl``, most recent first.", "operationId": "list_activity_api_v1_activity_get", "parameters": [{"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "maximum": 500, "minimum": 1, "default": 50, "title": "Limit"}}, {"name": "platform", "in": "query", "required": false, "schema": {"anyOf": [{"enum": ["facebook", "instagram", "wordpress"], "type": "string"}, {"type": "null"}], "title": "Platform"}}, {"name": "action", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Action"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ActivityResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/items/{item_id}": {"get": {"summary": "Get Item", "description": "Look up a single item by id. 410 for legacy comments.", "operationId": "get_item_api_v1_items__item_id__get", "parameters": [{"name": "item_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Item Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"anyOf": [{"$ref": "#/components/schemas/BlogPostItem"}, {"$ref": "#/components/schemas/GroupItem"}], "title": "Response Get Item Api V1 Items  Item Id  Get"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/items/{item_id}/approve": {"post": {"summary": "Approve Item", "description": "Approve an item. Dispatches on type.", "operationId": "approve_item_api_v1_items__item_id__approve_post", "parameters": [{"name": "item_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Item Id"}}, {"name": "channel", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string", "pattern": "^(both|fb_only|ig_only)$"}, {"type": "null"}], "title": "Channel"}}], "requestBody": {"content": {"application/json": {"schema": {"anyOf": [{"$ref": "#/components/schemas/ApproveBody"}, {"type": "null"}], "title": "Body"}}}}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DecisionResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/items/{item_id}/reject": {"post": {"summary": "Reject Item", "description": "Reject an item. Dispatches on type. Logs ``body.reason`` (free-form).", "operationId": "reject_item_api_v1_items__item_id__reject_post", "parameters": [{"name": "item_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Item Id"}}], "requestBody": {"content": {"application/json": {"schema": {"anyOf": [{"$ref": "#/components/schemas/RejectBody"}, {"type": "null"}], "title": "Body"}}}}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DecisionResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/items/{item_id}/edit": {"post": {"summary": "Edit Item", "description": "Approve with edited content. Only valid for blog_post items.", "operationId": "edit_item_api_v1_items__item_id__edit_post", "parameters": [{"name": "item_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Item Id"}}], "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EditBody"}}}}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DecisionResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/facebook/groups": {"get": {"summary": "List Facebook Groups", "description": "List all Facebook groups and their statuses.", "operationId": "list_facebook_groups_api_v1_facebook_groups_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/FacebookGroupsResponse"}}}}}}}, "/api/v1/facebook/groups/{group_name}": {"put": {"summary": "Update Facebook Group", "description": "Update a Facebook group's status.", "operationId": "update_facebook_group_api_v1_facebook_groups__group_name__put", "parameters": [{"name": "group_name", "in": "path", "required": true, "schema": {"type": "string", "title": "Group Name"}}], "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/FacebookGroupUpdateBody"}}}}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/FacebookGroup"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/health": {"get": {"summary": "Health", "description": "Liveness probe for launchd / curl. 204 = OK, no body needed.", "operationId": "health_api_v1_health_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}}, "components": {"schemas": {"ActivityEntry": {"properties": {"date": {"type": "string", "title": "Date"}, "timestamp": {"type": "string", "title": "Timestamp"}, "action": {"type": "string", "enum": ["comment", "like", "group_post", "reply", "own_reply", "page_post", "feed_post", "group_join"], "title": "Action"}, "platform": {"type": "string", "enum": ["facebook", "instagram", "wordpress"], "title": "Platform"}, "target_name": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Target Name"}, "target_url": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Target Url"}, "content": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Content"}, "reply_url": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Reply Url"}}, "additionalProperties": true, "type": "object", "required": ["date", "timestamp", "action", "platform"], "title": "ActivityEntry", "description": "One row in ``logs/engagement_log.jsonl`` as exposed by ``/activity``.\n\nSome legacy rows in the JSONL file use ``action=\"group_join_request\"``;\nthe API layer normalises those to ``\"group_join\"`` before constructing\nthis model so the frontend only ever sees the canonical value. Older\nrows may also lack the ``date`` field \u2014 ``lib.activity_log`` derives\nit from ``timestamp`` so the UI can rely on both being present."}, "ActivityResponse": {"properties": {"entries": {"items": {"$ref": "#/components/schemas/ActivityEntry"}, "type": "array", "title": "Entries"}, "total": {"type": "integer", "title": "Total"}, "as_of": {"type": "string", "title": "As Of"}}, "type": "object", "required": ["entries", "total", "as_of"], "title": "ActivityResponse", "description": "Envelope for ``GET /api/v1/activity``."}, "ApproveBody": {"properties": {"text": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Text"}, "fb_caption": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Fb Caption"}, "ig_caption": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Ig Caption"}}, "type": "object", "title": "ApproveBody", "description": "Body for ``POST /items/{id}/approve``.\n\nAll fields optional: a bare approve just commits the existing draft.\nPass ``text`` to override a comment, or ``fb_caption``/``ig_caption``\nto override a blog post pair before approval."}, "BlogPostItem": {"properties": {"id": {"type": "string", "title": "Id"}, "status": {"type": "string", "title": "Status", "default": "pending"}, "decided_by": {"anyOf": [{"type": "string", "enum": ["telegram", "web_ui", "auto"]}, {"type": "null"}], "title": "Decided By"}, "decided_at": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Decided At"}, "created_at": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Created At"}, "type": {"type": "string", "const": "blog_post", "title": "Type", "default": "blog_post"}, "post_title": {"type": "string", "title": "Post Title", "default": ""}, "post_url": {"type": "string", "title": "Post Url", "default": ""}, "post_id": {"type": "integer", "title": "Post Id", "default": 0}, "fb_caption": {"type": "string", "title": "Fb Caption", "default": ""}, "ig_caption": {"type": "string", "title": "Ig Caption", "default": ""}, "image_url": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Image Url"}, "channel": {"anyOf": [{"type": "string", "enum": ["both", "fb_only", "ig_only"]}, {"type": "null"}], "title": "Channel"}}, "additionalProperties": true, "type": "object", "required": ["id"], "title": "BlogPostItem", "description": "A WordPress post awaiting FB + IG caption sign-off.\n\n``channel`` is the per-platform fan-out decision set by the approver:\n\n- Web UI: ``POST /items/{id}/approve?channel=fb_only`` stamps this field\n  before flipping ``status`` to ``approved``.\n- Telegram: the reply parser in ``lib/notifier.py`` maps text replies\n  (``approve``/``fb``/``ig``) onto ``\"both\"``/``\"fb_only\"``/``\"ig_only\"``.\n\nThe publisher (``scripts/content_pipeline.py::stage_publish``) reads\n``channel`` after ``send_and_wait`` returns to decide which platforms to\nactually post to. ``None`` is valid only while the item is still pending\nor was skipped."}, "DecisionResponse": {"properties": {"id": {"type": "string", "title": "Id"}, "status": {"type": "string", "title": "Status"}, "decided_by": {"type": "string", "enum": ["telegram", "web_ui", "auto"], "title": "Decided By"}, "decided_at": {"type": "string", "title": "Decided At"}, "join_status": {"anyOf": [{"type": "string", "const": "queued"}, {"type": "null"}], "title": "Join Status"}}, "type": "object", "required": ["id", "status", "decided_by", "decided_at"], "title": "DecisionResponse", "description": "Returned on every commit endpoint."}, "EditBody": {"properties": {"text": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Text"}, "fb_caption": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Fb Caption"}, "ig_caption": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Ig Caption"}}, "type": "object", "title": "EditBody", "description": "Body for ``POST /items/{id}/edit``.\n\nEither ``text`` (comment items) or one/both of ``fb_caption`` /\n``ig_caption`` (blog-post items) must be set \u2014 enforced in the route\nhandler so the response is a clean 422 instead of an opaque ValidationError."}, "FacebookGroup": {"properties": {"group_name": {"type": "string", "title": "Group Name"}, "group_url": {"type": "string", "title": "Group Url"}, "status": {"type": "string", "title": "Status"}, "joined_at": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Joined At"}, "rules": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Rules"}, "last_post_at": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Last Post At"}, "source_notification": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Source Notification"}, "privacy": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Privacy"}, "member_count": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Member Count"}, "posting_mode": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Posting Mode"}, "notes": {"anyOf": [{"items": {"additionalProperties": {"type": "string"}, "type": "object"}, "type": "array"}, {"type": "null"}], "title": "Notes"}, "last_post_status": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Last Post Status"}, "last_post_caption": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Last Post Caption"}}, "additionalProperties": true, "type": "object", "required": ["group_name", "group_url", "status"], "title": "FacebookGroup", "description": "A Facebook group from groups_tracker.json."}, "FacebookGroupUpdateBody": {"properties": {"status": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Status"}, "posting_mode": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Posting Mode"}}, "type": "object", "title": "FacebookGroupUpdateBody", "description": "Body for PUT /api/v1/facebook/groups/{group_name}."}, "FacebookGroupsResponse": {"properties": {"groups": {"items": {"$ref": "#/components/schemas/FacebookGroup"}, "type": "array", "title": "Groups"}, "total": {"type": "integer", "title": "Total"}, "as_of": {"type": "string", "title": "As Of"}}, "type": "object", "required": ["groups", "total", "as_of"], "title": "FacebookGroupsResponse", "description": "Envelope for GET /api/v1/facebook/groups."}, "GroupItem": {"properties": {"id": {"type": "string", "title": "Id"}, "status": {"type": "string", "title": "Status", "default": "pending"}, "decided_by": {"anyOf": [{"type": "string", "enum": ["telegram", "web_ui", "auto"]}, {"type": "null"}], "title": "Decided By"}, "decided_at": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Decided At"}, "created_at": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Created At"}, "type": {"type": "string", "const": "group_to_join", "title": "Type", "default": "group_to_join"}, "name": {"type": "string", "title": "Name"}, "url": {"type": "string", "title": "Url"}, "member_count": {"anyOf": [{"type": "integer"}, {"type": "null"}], "title": "Member Count"}, "score": {"anyOf": [{"type": "number"}, {"type": "null"}], "title": "Score"}, "privacy": {"anyOf": [{"type": "string", "enum": ["public", "private"]}, {"type": "null"}], "title": "Privacy"}, "found_via_query": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Found Via Query"}, "competitor_mentions": {"anyOf": [{"type": "integer"}, {"type": "null"}], "title": "Competitor Mentions"}, "added_to_pending": {"type": "string", "title": "Added To Pending"}}, "additionalProperties": true, "type": "object", "required": ["id", "name", "url", "added_to_pending"], "title": "GroupItem", "description": "A Facebook group surfaced by ``fb_group_scout`` awaiting a join\ndecision.\n\nProducer side (``lib/group_discovery/state.py:add_to_pending``) writes\nthe discovery payload without ``id``/``status``/``decided_by`` \u2014 the API\nlayer synthesises those when reading (see ``lib/groups_queue.py``). The\n``model_config = extra=\"allow\"`` inherited from ``_ItemBase`` keeps the\nextra producer fields (``post_frequency``, ``competitor_names``,\n``description``) intact for the UI even though they aren't declared."}, "HTTPValidationError": {"properties": {"detail": {"items": {"$ref": "#/components/schemas/ValidationError"}, "type": "array", "title": "Detail"}}, "type": "object", "title": "HTTPValidationError"}, "PendingResponse": {"properties": {"items": {"items": {"oneOf": [{"$ref": "#/components/schemas/BlogPostItem"}, {"$ref": "#/components/schemas/GroupItem"}], "discriminator": {"propertyName": "type", "mapping": {"blog_post": "#/components/schemas/BlogPostItem", "group_to_join": "#/components/schemas/GroupItem"}}}, "type": "array", "title": "Items"}, "counts": {"additionalProperties": {"type": "integer"}, "type": "object", "title": "Counts"}, "as_of": {"type": "string", "title": "As Of"}}, "type": "object", "required": ["items", "counts", "as_of"], "title": "PendingResponse", "description": "Envelope for ``GET /api/v1/pending``."}, "RejectBody": {"properties": {"reason": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Reason"}}, "type": "object", "title": "RejectBody", "description": "Body for ``POST /items/{id}/reject``. ``reason`` is free-form."}, "ValidationError": {"properties": {"loc": {"items": {"anyOf": [{"type": "string"}, {"type": "integer"}]}, "type": "array", "title": "Location"}, "msg": {"type": "string", "title": "Message"}, "type": {"type": "string", "title": "Error Type"}}, "type": "object", "required": ["loc", "msg", "type"], "title": "ValidationError"}}}}
