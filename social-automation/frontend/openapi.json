legram","web_ui","auto"]},{"type":"null"}],"title":"Decided By"},"decided_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Decided At"},"created_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Created At"},"type":{"type":"string","const":"campaign_verify","title":"Type","default":"campaign_verify"},"seed_id":{"type":"string","title":"Seed Id","default":""},"title":{"type":"string","title":"Title","default":""},"wp_draft_url":{"type":"string","title":"Wp Draft Url","default":""},"audio_size_kb":{"anyOf":[{"type":"integer"},{"type":"null"}],"title":"Audio Size Kb"},"slide_count":{"anyOf":[{"type":"integer"},{"type":"null"}],"title":"Slide Count"}},"additionalProperties":true,"type":"object","required":["id"],"title":"CampaignVerifyItem","description":"A campaign awaiting final human verification before publish."},"CommentItem":{"properties":{"id":{"type":"string","title":"Id"},"status":{"type":"string","title":"Status","default":"pending"},"decided_by":{"anyOf":[{"type":"string","enum":["telegram","web_ui","auto"]},{"type":"null"}],"title":"Decided By"},"decided_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Decided At"},"created_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Created At"},"type":{"type":"string","const":"comment","title":"Type","default":"comment"},"platform":{"type":"string","enum":["facebook","instagram","wordpress","system"],"title":"Platform"},"group_or_hashtag":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Group Or Hashtag"},"post_url":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Post Url"},"post_text":{"type":"string","title":"Post Text","default":""},"draft_comment":{"type":"string","title":"Draft Comment","default":""},"relevance_score":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Relevance Score"}},"additionalProperties":true,"type":"object","required":["id","platform"],"title":"CommentItem","description":"A Facebook / Instagram / WordPress engagement comment.\n\nLegacy schema — engagement comments no longer flow through the web UI,\nbut the model is retained so the autonomous pipeline (comment_poster)\nand legacy items in ``comment_queue.json`` can still validate."},"DecisionResponse":{"properties":{"id":{"type":"string","title":"Id"},"status":{"type":"string","title":"Status"},"decided_by":{"type":"string","enum":["telegram","web_ui","auto"],"title":"Decided By"},"decided_at":{"type":"string","title":"Decided At"},"join_status":{"anyOf":[{"type":"string","const":"queued"},{"type":"null"}],"title":"Join Status"}},"type":"object","required":["id","status","decided_by","decided_at"],"title":"DecisionResponse","description":"Returned on every commit endpoint."},"EditBody":{"properties":{"text":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Text"},"fb_caption":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Fb Caption"},"ig_caption":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Ig Caption"}},"type":"object","title":"EditBody","description":"Body for ``POST /items/{id}/edit``.\n\nEither ``text`` (comment items) or one/both of ``fb_caption`` /\n``ig_caption`` (blog-post items) must be set — enforced in the route\nhandler so the response is a clean 422 instead of an opaque ValidationError."},"FacebookGroup":{"properties":{"group_name":{"type":"string","title":"Group Name"},"group_url":{"type":"string","title":"Group Url"},"status":{"type":"string","title":"Status"},"joined_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Joined At"},"rules":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Rules"},"last_post_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Last Post At"},"source_notification":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Source Notification"},"privacy":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Privacy"},"member_count":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Member Count"},"posting_mode":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Posting Mod