ummary":"Edit Item","description":"Approve with edited content. Only valid for blog_post items.","operationId":"edit_item_api_v1_items__item_id__edit_post","parameters":[{"name":"item_id","in":"path","required":true,"schema":{"type":"string","title":"Item Id"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/EditBody"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DecisionResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/facebook/groups":{"get":{"summary":"List Facebook Groups","description":"List all Facebook groups and their statuses.","operationId":"list_facebook_groups_api_v1_facebook_groups_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/FacebookGroupsResponse"}}}}}}},"/api/v1/facebook/groups/{group_name}":{"put":{"summary":"Update Facebook Group","description":"Update a Facebook group's status.","operationId":"update_facebook_group_api_v1_facebook_groups__group_name__put","parameters":[{"name":"group_name","in":"path","required":true,"schema":{"type":"string","title":"Group Name"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/FacebookGroupUpdateBody"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/FacebookGroup"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/health":{"get":{"summary":"Health","description":"Liveness probe for launchd / curl. 204 = OK, no body needed.","operationId":"health_api_v1_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/v1/flows/state":{"get":{"summary":"Get Flows State","description":"Aggregate per-flow health + launchd schedule snapshot for the UI.","operationId":"get_flows_state_api_v1_flows_state_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/FlowsStateResponse"}}}}}}},"/api/v1/schedule/{label}/trigger":{"post":{"summary":"Trigger Schedule","description":"Fire a launchd job on demand via ``launchctl start <label>``.\n\nLabel is whitelisted against the ``com.dogfoodandfun.*`` namespace\nto keep this from being abused as a generic launchctl runner. All\nsubprocess args are list-form; no shell.","operationId":"trigger_schedule_api_v1_schedule__label__trigger_post","parameters":[{"name":"label","in":"path","required":true,"schema":{"type":"string","title":"Label"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/TriggerResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"ActivityEntry":{"properties":{"date":{"type":"string","title":"Date"},"timestamp":{"type":"string","title":"Timestamp"},"action":{"type":"string","enum":["comment","like","group_post","reply","own_reply","page_post","feed_post","group_join","trace"],"title":"Action"},"platform":{"type":"string","enum":["facebook","instagram","wordpress"],"title":"Platform"},"target_name":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Target Name"},"target_url":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Target Url"},"content":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Content"},"reply_url":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Reply Url"}},"additionalProperties":true,"type":"object","required":["date","timestamp","action","platform"],"title":"ActivityEntry","description":"One row in ``logs/engagement_log.jsonl`` as exposed by ``/activity``.\n\nSome legacy rows in the JSONL file use ``action=\"group_join_request\"``;\nthe API layer normalises those to ``\"group_join\"`` before constructing\nthis model so the frontend only ever sees the canonical value. Older\nrows may also lack the ``date`` field â€” ``lib.activity_log`` derives\nit from ``timestamp`` so the UI can rely on both being present."},"ActivityResponse":{"properties":{"entries":{"items":{"$ref":"#/components/schemas/ActivityEntry"},"type":"array","title":"Entries"},"total":{"type":"integer","title":"Total"},"as_of":{"type":"string","title":"As Of"}},"type":"object","required":["entries","total","as_of"],"title":"ActivityResponse","description":"Envelope for ``GET /api/v1/activity``."},"ApproveBody":{"properties":{"text":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Text"},"fb_caption":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Fb Caption"},"ig_caption":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Ig Caption"}},"type":"object","title":"ApproveBody","description":"Body for ``POST /items/{id}/approve``.\n\nAll fields optional: a bare approve just commits the existing draft.\nPass ``text`` to override a comment, or ``fb_caption``/``ig_caption``\nto override a blog post pair before approval."},"BlogPostItem":{"properties":{"id":{"type":"string","title":"Id"},"status":{"type":"string","title":"Status","default":"pending"},"decided_by":{"anyOf":[{"type":"string","enum":["telegram","web_ui","auto"]},{"type":"null"}],"title":"Decided By"},"decided_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Decided At"},"created_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Created At"},"type":{"type":"string","const":"blog_post","title":"Type","default":"blog_post"},"post_title":{"type":"string","title":"Post Title","default":""},"post_url":{"type":"string","title":"Post Url","default":""},"post_id":{"type":"integer","title":"Post Id","default":0},"fb_caption":{"type":"string","title":"Fb Caption","default":""},"ig_caption":{"type":"string","title":"Ig Caption","default":""},"image_url":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Image Url"},"channel":{"anyOf":[{"type":"string","enum":["both","fb_only","ig_only"]},{"type":"null"}],"title":"Channel"}},"additionalProperties":true,"type":"object","required":["id"],"title":"BlogPostItem","description":"A WordPress post awaiting FB + IG caption sign-off.\n\n``channel`` is the per-platform fan-out decision set by the approver:\n\n- Web UI: ``POST /items/{id}/approve?channel=fb_only`` stamps this field\n  before flipping ``status`` to ``approved``.\n- Telegram: the reply parser in ``lib/notifier.py`` maps text replies\n  (``approve``/``fb``/``ig``) onto ``\"both\"``/``\"fb_only\"``/``\"ig_only\"``.\n\nThe publisher (``scripts/content_pipeline.py::stage_publish``) reads\n``channel`` after ``send_and_wait`` returns to decide which platforms to\nactually post to. ``None`` is valid only while the item is still pending\nor was skipped."},"DecisionResponse":{"properties":{"id":{"type":"string","title":"Id"},"status":{"type":"string","title":"Status"},"decided_by":{"type":"string","enum":["telegram","web_ui","auto"],"title":"Decided By"},"decided_at":{"type":"string","title":"Decided At"},"join_status":{"anyOf":[{"type":"string","const":"queued"},{"type":"null"}],"title":"Join Status"}},"type":"object","required":["id","status","decided_by","decided_at"],"title":"DecisionResponse","description":"Returned on every commit endpoint."},"EditBody":{"properties":{"text":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Text"},"fb_caption":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Fb Caption"},"ig_caption":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Ig Caption"}},"type":"object","title":"EditBody","description":"Body for ``POST /items/{id}/edit``.\n\nEither ``text`` (comment items) or one/both of ``fb_caption`` /\n``ig_caption`` (blog-post items) must be set â€” enforced in the route\nhandler so the response is a clean 422 instead of an opaque ValidationError."},"FacebookGroup":{"properties":{"group_name":{"type":"string","title":"Group Name"},"group_url":{"type":"string","title":"Group Url"},"status":{"type":"string","title":"Status"},"joined_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Joined At"},"rules":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Rules"},"last_post_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Last Post At"},"source_notification":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Source Notification"},"privacy":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Privacy"},"member_count":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Member Count"},"posting_mode":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Posting Mode"},"notes":{"anyOf":[{"items":{"additionalProperties":{"type":"string"},"type":"object"},"type":"array"},{"type":"null"}],"title":"Notes"},"last_post_status":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Last Post Status"},"last_post_caption":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Last Post Caption"}},"additionalProperties":true,"type":"object","required":["group_name","group_url","status"],"title":"FacebookGroup","description":"A Facebook group from groups_tracker.json."},"FacebookGroupUpdateBody":{"properties":{"status":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Status"},"posting_mode":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Posting Mode"}},"type":"object","title":"FacebookGroupUpdateBody","description":"Body for PUT /api/v1/facebook/groups/{group_name}."},"FacebookGroupsResponse":{"properties":{"groups":{"items":{"$ref":"#/components/schemas/FacebookGroup"},"type":"array","title":"Groups"},"total":{"type":"integer","title":"Total"},"as_of":{"type":"string","title":"As Of"}},"type":"object","required":["groups","total","as_of"],"title":"FacebookGroupsResponse","description":"Envelope for GET /api/v1/facebook/groups."},"FlowState":{"properties":{"id":{"type":"string","title":"Id"},"name":{"type":"string","title":"Name"},"last_run_at":{"anyOf":[{"type":"string","format":"date-time"},{"type":"null"}],"title":"Last Run At"},"last_status":{"type":"string","enum":["ok","error","never","stale","manual"],"title":"Last Status"},"error_message":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Error Message"},"output_counts":{"additionalProperties":{"type":"integer"},"type":"object","title":"Output Counts"},"sample":{"items":{"additionalProperties":true,"type":"object"},"type":"array","title":"Sample"}},"type":"object","required":["id","name","last_status","output_counts","sample"],"title":"FlowState","description":"One row in the ``/flows/state`` response â€” health snapshot of a flow.\n\nSix top-level flows surface to the UI: engagement-comment, blog-campaign,\ncommunity-growth, social-loyalty, market-intel, content-ideas. Each\nreader assembles its own ``output_counts`` shape (keys vary per flow);\nthe UI renders them generically. ``sample`` is a small (â‰¤3) tail of the\nmost recent items the flow produced, redacted of any token/secret/\npassword/cookie/auth-keyed fields before serialisation."},"FlowsStateResponse":{"properties":{"flows":{"items":{"$ref":"#/components/schemas/FlowState"},"type":"array","title":"Flows"},"schedule":{"items":{"$ref":"#/components/schemas/ScheduleEntry"},"type":"array","title":"Schedule"}},"type":"object","required":["flows","schedule"],"title":"FlowsStateResponse","description":"Envelope for ``GET /api/v1/flows/state``."},"GroupItem":{"properties":{"id":{"type":"string","title":"Id"},"status":{"type":"string","title":"Status","default":"pending"},"decided_by":{"anyOf":[{"type":"string","enum":["telegram","web_ui","auto"]},{"type":"null"}],"title":"Decided By"},"decided_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Decided At"},"created_at":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Created At"},"type":{"type":"string","const":"group_to_join","title":"Type","default":"group_to_join"},"name":{"type":"string","title":"Name"},"url":{"type":"string","title":"Url"},"member_count":{"anyOf":[{"type":"integer"},{"type":"null"}],"title":"Member Count"},"score":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Score"},"privacy":{"anyOf":[{"type":"string","enum":["public","private"]},{"type":"null"}],"title":"Privacy"},"found_via_query":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Found Via Query"},"competitor_mentions":{"anyOf":[{"type":"integer"},{"type":"null"}],"title":"Competitor Mentions"},"added_to_pending":{"type":"string","title":"Added To Pending"}},"additionalProperties":true,"type":"object","required":["id","name","url","added_to_pending"],"title":"GroupItem","description":"A Facebook group surfaced by ``fb_group_scout`` awaiting a join\ndecision.\n\nProducer side (``lib/group_discovery/state.py:add_to_pending``) writes\nthe discovery payload without ``id``/``status``/``decided_by`` â€” the API\nlayer synthesises those when reading (see ``lib/groups_queue.py``). The\n``model_config = extra=\"allow\"`` inherited from ``_ItemBase`` keeps the\nextra producer fields (``post_frequency``, ``competitor_names``,\n``description``) intact for the UI even though they aren't declared."},"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"PendingResponse":{"properties":{"items":{"items":{"oneOf":[{"$ref":"#/components/schemas/BlogPostItem"},{"$ref":"#/components/schemas/GroupItem"}],"discriminator":{"propertyName":"type","mapping":{"blog_post":"#/components/schemas/BlogPostItem","group_to_join":"#/components/schemas/GroupItem"}}},"type":"array","title":"Items"},"counts":{"additionalProperties":{"type":"integer"},"type":"object","title":"Counts"},"as_of":{"type":"string","title":"As Of"}},"type":"object","required":["items","counts","as_of"],"title":"PendingResponse","description":"Envelope for ``GET /api/v1/pending``."},"RejectBody":{"properties":{"reason":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Reason"}},"type":"object","title":"RejectBody","description":"Body for ``POST /items/{id}/reject``. ``reason`` is free-form."},"ScheduleEntry":{"properties":{"label":{"type":"string","title":"Label"},"flow_id":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Flow Id"},"schedule_human":{"type":"string","title":"Schedule Human"},"last_fire_at":{"anyOf":[{"type":"string","format":"date-time"},{"type":"null"}],"title":"Last Fire At"},"last_exit_code":{"anyOf":[{"type":"integer"},{"type":"null"}],"title":"Last Exit Code"},"is_loaded":{"type":"boolean","title":"Is Loaded"}},"type":"object","required":["label","schedule_human","is_loaded"],"title":"ScheduleEntry","description":"One launchd job in the ``/flows/state`` schedule list.\n\nSourced from ``launchctl list`` + ``~/Library/LaunchAgents/com.<brand>.*``\nplist files. ``is_loaded`` is True iff the label currently appears in\n``launchctl list`` output. ``last_exit_code`` is the second column from\nlaunchctl (parsed int, or None when not loaded / waiting). ``flow_id``\nmaps the cron label back to the parent flow when one exists, else None."},"TriggerResponse":{"properties":{"ok":{"type":"boolean","title":"Ok"},"message":{"type":"string","title":"Message"},"label":{"type":"string","title":"Label"}},"type":"object","required":["ok","message","label"],"title":"TriggerResponse","description":"Envelope for ``POST /api/v1/schedule/{label}/trigger``."},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}}}}